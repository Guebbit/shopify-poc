# Dev tooling (shared by nuxt devServer, docker-compose.yml and cypress.config.ts)
APP_PORT = 8080

# i18n: locales are build-time config, see the i18n block in nuxt.config.ts (files in i18n/locales).

# Shopify Storefront API (public token, safe to expose client-side)
NUXT_PUBLIC_SHOPIFY_ENDPOINT = https://callmewine-stage-uk.myshopify.com/api/2026-04/graphql.json
NUXT_PUBLIC_SHOPIFY_TOKEN = yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
NUXT_PUBLIC_SHOPIFY_PRODUCT_GID = gid://shopify/Product/xxxxxxxxxxxx
