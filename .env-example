# App settings
VITE_APP_DEFAULT_LOCALE = en
VITE_APP_FALLBACK_LOCALE = en
VITE_APP_SUPPORTED_LOCALES = en,it,es,fr
VITE_APP_PUBLIC_PATH = /
# VITE_APP_BASE_URL # createRouter.history = createWebHistory()

# API settings
VITE_APP_PORT = 8080

# Runtime config (see nuxt.config.ts runtimeConfig.public) — NUXT_PUBLIC_ prefix is required for Nuxt to pick these up.
NUXT_PUBLIC_API_BASE_URL = http://localhost:3000
NUXT_PUBLIC_AXIOS_TIMEOUT = 10000

# Shopify Storefront API (public token, safe to expose client-side)
NUXT_PUBLIC_SHOPIFY_ENDPOINT = https://callmewine-stage-uk.myshopify.com/api/2026-04/graphql.json
NUXT_PUBLIC_SHOPIFY_TOKEN = yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
NUXT_PUBLIC_SHOPIFY_PRODUCT_GID = gid://shopify/Product/xxxxxxxxxxxx
